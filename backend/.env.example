# ==========================================
# Backend Environment Variables Template
# ==========================================

# Local Development Only: Express server port
# Default (if not provided): 3001
PORT=3001

# Local Development Only: Path to Firebase service account key
# Default (if not provided): none (will rely on default GCP credentials or fail locally if not set)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Auth Bypass Toggle
# Set to 'false' (or remove) in production to enforce real LINE JWT verification
# Set to 'true' locally to allow 'fake-liff-token' from frontend during testing
# Default (if not provided): false (will block fake-liff-token requests)
MOCK_LIFF_TOKEN=true
