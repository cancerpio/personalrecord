# ==========================================
# Frontend Environment Variables Template
# ==========================================

# Storage Mode: 'local' (offline localStorage) or 'liff' (connect to backend API)
# Default (if not provided): local
VITE_STORAGE_MODE=liff

# API Base URL: Point to your backend (local Node.js or deployed Firebase URL)
# Local: http://localhost:3001/api/v1
# Cloud: https://asia-east1-your-project-id.cloudfunctions.net/api/v1
# Default (if not provided): http://localhost:3001/api/v1
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Local Development Only: Skip real LINE login and use fake token for API testing
# Set to 'true' when you want to bypass LINE login locally.
# Default (if not provided): false (will attempt real liff.init() flow)
VITE_MOCK_LIFF_TOKEN=false
